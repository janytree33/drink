# ================================================================
# 🔑 Supabase 접속 키 샘플 파일 (.env.example)
# ================================================================
# 이 파일은 GitHub에 올라가는 "예시 파일"입니다.
# 실제 키 값은 비워두고, 어떤 값을 넣어야 하는지 안내만 합니다.
# ================================================================

VITE_SUPABASE_URL=https://여기에_프로젝트_URL.supabase.co
VITE_SUPABASE_ANON_KEY=여기에_ANON_PUBLIC_KEY_붙여넣기
